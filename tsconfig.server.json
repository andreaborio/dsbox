{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "outDir": "dist-server",
    "declaration": false,
    "sourceMap": true,
    "types": ["node"]
  },
  "include": ["server/**/*.ts", "src/types.ts", "tests/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
