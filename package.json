{
  "name": "hebrus-studio",
  "version": "0.4.0",
  "private": true,
  "description": "The open desktop studio for Hebrus, a Metal-first inference engine with SSD streaming.",
  "author": "Hebrus Studio contributors",
  "license": "MIT",
  "main": "desktop/main.cjs",
  "keywords": [
    "hebrus",
    "ds4",
    "metal",
    "apple-silicon",
    "local-llm",
    "ssd-streaming"
  ],
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,ui -c magenta,cyan \"tsx watch server/index.ts\" \"vite\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:web": "vite",
    "build": "tsc -p tsconfig.server.build.json && vite build",
    "build:icon": "bash scripts/build-macos-icon.sh",
    "desktop": "npm run build && electron .",
    "build:provenance:dev": "node scripts/generate-development-provenance.mjs",
    "build:legal-notices": "node node_modules/electron/install.js",
    "pack:mac": "npm run build:provenance:dev && npm run build:legal-notices && npm run build:icon && npm run build && electron-builder --config electron-builder.dev.yml --mac dir --arm64",
    "dist:mac": "npm run build:legal-notices && npm run build:icon && npm run build && electron-builder --mac dmg --arm64 --publish never",
    "dist:mac:dev": "node scripts/clean-public-release-assets.mjs release && npm run build:provenance:dev && npm run build:legal-notices && npm run build:icon && npm run build && electron-builder --config electron-builder.dev.yml --mac dmg --arm64 --publish never",
    "verify:mac": "bash scripts/verify-macos-release.sh",
    "verify:mac:dev": "bash scripts/verify-macos-release.sh --development",
    "verify:upgrade-rollback:e2e": "bash scripts/run-upgrade-rollback-e2e.sh",
    "verify:upgrade-rollback:e2e:dev-dmg": "bash scripts/run-upgrade-rollback-e2e.sh --development",
    "release:readiness": "node scripts/check-public-release-readiness.mjs --status",
    "release:readiness:strict": "node scripts/check-public-release-readiness.mjs --strict",
    "release:provenance": "node scripts/generate-release-provenance.mjs --output build/release-provenance.json",
    "release:attestation:create": "node scripts/create-release-attestation.mjs",
    "release:attestation:validate": "node scripts/validate-release-attestation.mjs",
    "release:sbom:validate": "node scripts/validate-release-sbom.mjs",
    "release:licenses": "node scripts/create-release-license-inventory.mjs",
    "release:e2e:report:validate": "node scripts/validate-upgrade-rollback-report.mjs",
    "development:e2e:report:validate": "node scripts/validate-development-upgrade-rollback-report.mjs",
    "release:checksums": "node scripts/create-release-checksums.mjs release",
    "release:checksums:validate": "node scripts/validate-release-checksums.mjs release",
    "start": "node dist-server/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:theme-colors": "node scripts/check-theme-colors.mjs",
    "check:brand": "node scripts/check-brand-boundaries.mjs",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "express": "^5.2.1",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron/asar": "3.4.1",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "9.2.4",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "spdx-expression-parse": "5.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
