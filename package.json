{
  "name": "dsbox",
  "version": "0.2.5",
  "private": true,
  "description": "A polished local launcher and agent gateway for andreaborio/ds4 on Apple Silicon.",
  "author": "DSBox",
  "license": "MIT",
  "main": "desktop/main.cjs",
  "keywords": [
    "ds4",
    "metal",
    "apple-silicon",
    "local-llm",
    "ssd-streaming"
  ],
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,ui -c magenta,cyan \"tsx watch server/index.ts\" \"vite\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:web": "vite",
    "build": "tsc -p tsconfig.server.build.json && vite build",
    "desktop": "npm run build && electron .",
    "pack:mac": "npm run build && electron-builder --mac dir --arm64",
    "dist:mac": "npm run build && electron-builder --mac dmg --arm64 --publish never",
    "verify:mac": "bash scripts/verify-macos-release.sh",
    "start": "node dist-server/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:theme-colors": "node scripts/check-theme-colors.mjs",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "express": "^5.2.1",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "supertest": "^7.2.2",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
